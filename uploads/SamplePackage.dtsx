      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <DTS:Executables>
    <!-- Execute SQL Task -->
    <DTS:Executable
      DTS:refId="Package\Truncate Target Table"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{66666666-6666-6666-6666-666666666666}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Truncate Target Table"
      DTS:TaskContact="Execute SQL Task">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="{33333333-3333-3333-3333-333333333333}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE dbo.Customers" />
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- Data Flow Task -->
    <DTS:Executable
      DTS:refId="Package\Load Customer Data"
      DTS:CreationName="Microsoft.Pipeline"
      DTS:DTSID="{77777777-7777-7777-7777-777777777777}"
      DTS:ExecutableType="Microsoft.Pipeline"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Customer Data"
      DTS:TaskContact="Data Flow Task">
      <DTS:ObjectData>
        <pipeline version="1">
          <components>
            <component
              refId="Package\Load Customer Data\OLE DB Source"
              componentClassID="Microsoft.OLEDBSource"
              name="OLE DB Source"
              version="7">
              <properties>
                <property name="SqlCommand" dataType="System.String">SELECT CustomerID, Name, Email FROM dbo.SourceCustomers</property>
              </properties>
            </component>
            <component
              refId="Package\Load Customer Data\Lookup"
              componentClassID="Microsoft.Lookup"
              name="Lookup"
              version="7">
              <properties>
                <property name="CacheType" dataType="System.String">Full</property>
              </properties>
            </component>
            <component
              refId="Package\Load Customer Data\Derived Column"
              componentClassID="Microsoft.DerivedColumn"
              name="Derived Column"
              version="7">
              <properties>
                <property name="DerivedColumnExpressions" dataType="System.String">UPPER(Name)</property>
              </properties>
            </component>
            <component
              refId="Package\Load Customer Data\OLE DB Destination"
              componentClassID="Microsoft.OLEDBDestination"
              name="OLE DB Destination"
              version="7">
              <properties>
                <property name="TableOrViewName" dataType="System.String">[dbo].[Customers]</property>
              </properties>
            </component>
          </components>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- For Each Loop Container -->
    <DTS:Executable
      DTS:refId="Package\Process Files"
      DTS:CreationName="Microsoft.ForEachLoopContainer"
      DTS:DTSID="{88888888-8888-8888-8888-888888888888}"
      DTS:ExecutableType="Microsoft.ForEachLoopContainer"
