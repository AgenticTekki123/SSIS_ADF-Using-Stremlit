    </DTS:Variable>
  </DTS:Variables>

  <DTS:ConnectionManagers>
    <DTS:ConnectionManager
      DTS:refId="Package.ConnectionManagers[OnPremSQLSource]"
      DTS:CreationName="OLEDB"
      DTS:DTSID="{33333333-3333-3333-3333-333333333333}"
      DTS:ObjectName="OnPremSQLSource"
      DTS:Description="Connection to On-Premises SQL Server">
      <DTS:ObjectData>
        <DTS:ConnectionManager
          DTS:ConnectionString="Data Source=192.168.1.50;Initial Catalog=SourceDB;Provider=SQLOLEDB.1;Integrated Security=SSPI;" />
