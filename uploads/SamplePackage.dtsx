      <DTS:ObjectData>
        <DTS:ConnectionManager
          DTS:ConnectionString="Data Source=tcp:your-sql-server.database.windows.net;Initial Catalog=TargetDB;User ID=sqluser;Password=***;Provider=SQLOLEDB.1;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>

    <DTS:ConnectionManager
      DTS:refId="Package.ConnectionManagers[FlatFileSource]"
      DTS:CreationName="FLATFILE"
      DTS:DTSID="{55555555-5555-5555-5555-555555555555}"
