          DTS:ObjectName="Process Single File" />
      </DTS:Executables>
    </DTS:Executable>

    <!-- Script Task -->
    <DTS:Executable
      DTS:refId="Package\Send Notification"
      DTS:CreationName="Microsoft.ScriptTask"
      DTS:DTSID="{AAAAAAAA-AAAA-AAAA-AAAA-AAAAAAAAAAAA}"
      DTS:ExecutableType="Microsoft.ScriptTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Send Notification"
      DTS:TaskContact="Script Task">
      <DTS:ObjectData>
        <ScriptProject
          Name="ST_1234567890"
          Language="CSharp"
          EntryPoint="ScriptMain.cs" />
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- Execute Package Task -->
    <DTS:Executable
      DTS:refId="Package\Call Child Package"
      DTS:CreationName="Microsoft.ExecutePackageTask"
      DTS:DTSID="{BBBBBBBB-BBBB-BBBB-BBBB-BBBBBBBBBBBB}"
      DTS:ExecutableType="Microsoft.ExecutePackageTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Call Child Package"
      DTS:TaskContact="Execute Package Task">
      <DTS:ObjectData>
        <ExecutePackageTask
          PackageName="ChildPackage.dtsx"
          PackagePath="C:\SSIS\ChildPackage.dtsx" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>

  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Constraint 1]"
      DTS:CreationName=""
      DTS:DTSID="{CCCCCCCC-CCCC-CCCC-CCCC-CCCCCCCCCCCC}"
      DTS:From="Package\Truncate Target Table"
      DTS:LogicalAnd="True"
